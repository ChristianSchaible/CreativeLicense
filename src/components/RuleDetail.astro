---
import { withBase } from "../utils/withBase";

interface Props {
  rule: string;
  author: string;
  visualizedBy: string;
  finalOutputImage?: string;
  finalOutputImages?: string[];
  description: string;
  process: string;
  images: string[];
  backHref: string;
  backLabel: string;
  transitionName: string;
}

const {
  rule,
  author,
  visualizedBy,
  finalOutputImage,
  finalOutputImages,
  description,
  process,
  images,
  backHref,
  backLabel,
  transitionName,
} = Astro.props;

const outputImages = finalOutputImages?.length ? finalOutputImages : finalOutputImage ? [finalOutputImage] : [];

const outputImageLabels = outputImages.map((_, index) => `Final output ${index + 1} for ${rule}`);
const processImageLabels = images.map((_, index) => `Process image ${index + 1} for ${rule}`);
---

<article class="rule-detail">
  <header class="rule-detail__header" transition:name={transitionName}>
    <h1 class="rule-detail__title">"{rule}"</h1>
  </header>

  <div class="output">
    <h2 class="section-layout__subtitle">Output</h2>

    <div class="rule-detail__content">
      {outputImages.length > 0 && (
        <div class="rule-detail__final-output">
          <div class="rule-detail__gallery">
            {outputImages.map((image, index) => (
              <figure class="rule-detail__figure">
                <button
                  type="button"
                  class="rule-detail__lightbox-trigger"
                  data-lightbox-trigger
                  data-lightbox-src={withBase(image)}
                  data-lightbox-alt={outputImageLabels[index]}
                  data-lightbox-caption={outputImageLabels[index]}
                  data-lightbox-index={index}
                  aria-label={`Open ${outputImageLabels[index]}`}
                >
                  <img src={withBase(image)} alt="" aria-hidden="true" class="rule-detail__img" />
                </button>
              </figure>
            ))}
          </div>
        </div>
      )}

      <section class="rule-detail__section">
        <div class="rule-detail__description-row">
          <p class="rule-detail__text">{description}</p>

          <aside class="rule-detail__meta" aria-label="Rule attribution">
            {author && (
              <p class="rule-detail__meta-item">
                <span class="rule-detail__meta-label">Author</span>
                <span class="rule-detail__meta-value">{author}</span>
              </p>
            )}
            {visualizedBy && (
              <p class="rule-detail__meta-item">
                <span class="rule-detail__meta-label">Visualized By</span>
                <span class="rule-detail__meta-value">{visualizedBy}</span>
              </p>
            )}
          </aside>
        </div>
      </section>

      <section class="rule-detail__section">
        <h2 class="rule-detail__subtitle">Process</h2>
        <p class="rule-detail__text">{process}</p>
      </section>

      {images.length > 0 && (
        <section class="rule-detail__section rule-detail__images">
          <div class="rule-detail__gallery">
            {images.map((image, index) => (
              <figure class="rule-detail__figure">
                <button
                  type="button"
                  class="rule-detail__lightbox-trigger"
                  data-lightbox-trigger
                  data-lightbox-src={withBase(image)}
                  data-lightbox-alt={processImageLabels[index]}
                  data-lightbox-caption={processImageLabels[index]}
                  data-lightbox-index={outputImages.length + index}
                  aria-label={`Open ${processImageLabels[index]}`}
                >
                  <img src={withBase(image)} alt="" aria-hidden="true" class="rule-detail__img" />
                </button>
              </figure>
            ))}
          </div>
        </section>
      )}
    </div>
  </div>

  <div class="rule-detail__lightbox" data-lightbox hidden aria-hidden="true">
    <div class="rule-detail__lightbox-backdrop" data-lightbox-close></div>

    <div class="rule-detail__lightbox-panel" role="dialog" aria-modal="true" aria-label="Image lightbox">
      <button type="button" class="rule-detail__lightbox-close" data-lightbox-close aria-label="Close image viewer">×</button>
      <button type="button" class="rule-detail__lightbox-nav rule-detail__lightbox-nav--prev" data-lightbox-prev aria-label="Previous image">←</button>

      <figure class="rule-detail__lightbox-stage">
        <img class="rule-detail__lightbox-image" data-lightbox-image alt="" />
        <figcaption class="rule-detail__lightbox-caption" data-lightbox-caption></figcaption>
      </figure>

      <button type="button" class="rule-detail__lightbox-nav rule-detail__lightbox-nav--next" data-lightbox-next aria-label="Next image">→</button>
    </div>
  </div>

  <footer class="rule-detail__footer">
    <a href={backHref} class="rule-detail__back-link">{backLabel}</a>
  </footer>
</article>

  <script>
    const lightbox = document.querySelector("[data-lightbox]");
    const triggers = Array.from(document.querySelectorAll("[data-lightbox-trigger]"));

    if (lightbox && triggers.length > 0) {
      const image = lightbox.querySelector("[data-lightbox-image]");
      const caption = lightbox.querySelector("[data-lightbox-caption]");
      const prevButton = lightbox.querySelector("[data-lightbox-prev]");
      const nextButton = lightbox.querySelector("[data-lightbox-next]");
      const closeButtons = Array.from(lightbox.querySelectorAll("[data-lightbox-close]"));

      const items = triggers
        .map((trigger) => ({
          src: trigger.dataset.lightboxSrc || "",
          alt: trigger.dataset.lightboxAlt || "",
          caption: trigger.dataset.lightboxCaption || "",
        }))
        .filter((item) => item.src);

      if (items.length > 0 && image && caption && prevButton && nextButton) {
        let currentIndex = 0;
        let lastTrigger = null;

        const update = () => {
          const item = items[currentIndex];
          image.src = item.src;
          image.alt = item.alt;
          caption.textContent = item.caption;
        };

        const open = (index, trigger) => {
          currentIndex = (index + items.length) % items.length;
          lastTrigger = trigger || null;
          update();
          lightbox.hidden = false;
          lightbox.classList.add("is-open");
          document.body.style.overflow = "hidden";
          closeButtons[0]?.focus();
        };

        const close = () => {
          lightbox.hidden = true;
          lightbox.classList.remove("is-open");
          document.body.style.overflow = "";
          lastTrigger?.focus?.();
        };

        const go = (step) => {
          currentIndex = (currentIndex + step + items.length) % items.length;
          update();
        };

        triggers.forEach((trigger, index) => {
          trigger.addEventListener("click", () => open(index, trigger));
        });

        prevButton.addEventListener("click", () => go(-1));
        nextButton.addEventListener("click", () => go(1));
        closeButtons.forEach((button) => button.addEventListener("click", close));

        lightbox.addEventListener("click", (event) => {
          const target = event.target;
          if (target === lightbox || (target instanceof Element && target.hasAttribute("data-lightbox-close"))) {
            close();
          }
        });

        document.addEventListener("keydown", (event) => {
          if (lightbox.hidden) return;

          if (event.key === "Escape") {
            close();
          }

          if (event.key === "ArrowLeft") {
            go(-1);
          }

          if (event.key === "ArrowRight") {
            go(1);
          }
        });
      } else {
        lightbox.remove();
      }
    }
  </script>

<style>
  .rule-detail {
    width: 100%;
  }

  .rule-detail__header {
    margin: var(--margin);
  }

  .rule-detail__title {
    font-family: var(--font-headings);
    font-size: clamp(2.5rem, 8vw, 7rem);
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .rule-detail__content {
    width: fit-content;
    max-width: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .rule-detail__section {
    opacity: 0;
    transform: translateY(18px);
    animation: detail-fade-up 560ms ease-out forwards;
    display: flex;
    flex-direction: column;
  }

  .rule-detail__section:nth-of-type(1) {
    animation-delay: 80ms;
    border: 1px solid var(--color-accent);
    padding: var(--padding);
    border-radius: var(--radius-inner);
  }

  .rule-detail__section:nth-of-type(2) {
    animation-delay: 180ms;
    border: 1px solid var(--color-accent);
    padding: var(--padding);
    border-radius: var(--radius-inner);
  }

  .rule-detail__section:nth-of-type(3) {
    animation-delay: 280ms;
    border: 1px solid var(--color-accent);
    padding: var(--padding);
    border-radius: var(--radius-inner);
  }

  .rule-detail__subtitle {
    font-family: var(--font-headings);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-accent);
    padding-bottom: 0.75rem;
  }

  .rule-detail__text {
    font-size: clamp(1rem, 2vw, 1.125rem);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .rule-detail__description-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(14rem, 20rem);
    gap: 1.25rem;
    align-items: start;
  }

  .rule-detail__meta {
    border-left: 1px solid var(--color-accent);
    padding-left: 1rem;
  }

  .rule-detail__meta-item {
    margin: 0 0 1rem;
    display: grid;
    gap: 0.2rem;
  }

  .rule-detail__meta-label {
    font-family: var(--font-headings);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.8;
  }

  .rule-detail__meta-value {
    font-size: 1rem;
    line-height: 1.4;
  }

  .rule-detail__images {
    max-width: 100%;
  }

  .rule-detail__final-output {
    width: 100%;
    opacity: 0;
    transform: translateY(18px);
    animation: detail-fade-up 560ms ease-out 80ms forwards;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border: 1px solid var(--color-accent);
    padding: var(--padding);
    border-radius: var(--radius-inner);
  }

  .rule-detail__gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
  }

  .rule-detail__final-output .rule-detail__gallery {
    width: 100%;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    align-items: start;
  }

  .rule-detail__figure {
    margin: 0;
  }

  .rule-detail__final-output .rule-detail__figure {
    width: 100%;
    min-width: 0;
  }

  .rule-detail__lightbox-trigger {
    display: block;
    position: relative;
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
    cursor: zoom-in;
    border-radius: calc(var(--radius-inner) - 2px);
    overflow: hidden;
    box-shadow: 0 0 0 1px rgb(255 255 255 / 0.14);
    transition: transform 180ms ease, box-shadow 180ms ease, filter 180ms ease;
  }

  .rule-detail__lightbox-trigger::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgb(255 255 255 / 0.08), rgb(0 0 0 / 0));
    opacity: 0;
    transition: opacity 180ms ease;
    pointer-events: none;
  }

  .rule-detail__lightbox-trigger:hover,
  .rule-detail__lightbox-trigger:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 14px 36px rgb(0 0 0 / 0.34), 0 0 0 1px rgb(255 255 255 / 0.28);
  }

  .rule-detail__lightbox-trigger:hover::after,
  .rule-detail__lightbox-trigger:focus-visible::after {
    opacity: 1;
  }

  .rule-detail__img {
    width: 100%;
    height: auto;
    display: block;
  }

  .rule-detail__final-output .rule-detail__img {
    width: 100%;
    height: auto;
    max-width: 100%;
    object-fit: contain;
  }

  .rule-detail__lightbox {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: grid;
    place-items: center;
  }

  .rule-detail__lightbox[hidden] {
    display: none;
  }

  .rule-detail__lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 0.9);
    backdrop-filter: blur(12px);
  }

  .rule-detail__lightbox-panel {
    position: relative;
    z-index: 1;
    width: min(94vw, 1500px);
    max-height: 90vh;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    padding: 1rem;
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-inner);
    background: rgb(10 10 10 / 0.95);
  }

  .rule-detail__lightbox-stage {
    margin: 0;
    min-width: 0;
    display: grid;
    gap: 0.75rem;
    justify-items: center;
  }

  .rule-detail__lightbox-image {
    display: block;
    max-width: 100%;
    max-height: 76vh;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .rule-detail__lightbox-caption {
    font-family: var(--font-headings);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-align: center;
    color: var(--color-text);
  }

  .rule-detail__lightbox-close,
  .rule-detail__lightbox-nav {
    appearance: none;
    border: 1px solid rgb(255 255 255 / 0.18);
    background: rgb(255 255 255 / 0.08);
    backdrop-filter: blur(14px);
    color: var(--color-accent);
    font-family: var(--font-headings);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    display: grid;
    place-items: center;
    min-width: 4rem;
    min-height: 4rem;
    border-radius: var(--radius-pill);
    box-shadow: 0 12px 30px rgb(0 0 0 / 0.35);
    transition: transform 180ms ease, background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease, opacity 180ms ease;
  }

  .rule-detail__lightbox-close:hover,
  .rule-detail__lightbox-nav:hover,
  .rule-detail__lightbox-close:focus-visible,
  .rule-detail__lightbox-nav:focus-visible {
    background: rgb(255 255 255 / 0.16);
    border-color: rgb(255 255 255 / 0.4);
    transform: translateY(-1px);
    box-shadow: 0 16px 34px rgb(0 0 0 / 0.42);
  }

  .rule-detail__lightbox-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 2;
    font-size: 1.9rem;
    line-height: 1;
    padding: 0;
  }

  .rule-detail__lightbox-nav {
    align-self: center;
    justify-self: center;
    padding: 0;
    font-size: 1.6rem;
    line-height: 1;
    min-inline-size: 4.5rem;
  }

  .rule-detail__lightbox-nav:disabled {
    opacity: 0.35;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .rule-detail__lightbox-trigger:focus-visible,
  .rule-detail__lightbox-close:focus-visible,
  .rule-detail__lightbox-nav:focus-visible {
    outline: 3px solid var(--color-focus-ring);
    outline-offset: 3px;
  }

  @media (max-width: 900px) {
    .rule-detail__lightbox-panel {
      width: min(96vw, 1500px);
      grid-template-columns: 1fr;
      gap: 0.75rem;
      padding-top: 3.25rem;
    }

    .rule-detail__lightbox-nav {
      width: 100%;
    }

    .rule-detail__lightbox-nav--prev {
      order: 2;
    }

    .rule-detail__lightbox-stage {
      order: 1;
    }

    .rule-detail__lightbox-nav--next {
      order: 3;
    }
  }

  .rule-detail__footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-accent);
    opacity: 0;
    transform: translateY(18px);
    animation: detail-fade-up 560ms ease-out 360ms forwards;
  }

  .rule-detail__back-link {
    font-family: var(--font-headings);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: var(--color-accent);
    transition: opacity 0.3s ease;
  }

  .rule-detail__back-link:hover,
  .rule-detail__back-link:focus-visible {
    opacity: 0.7;
  }

  .output {
    display: flex;
    flex-direction: row;
    gap: 1rem;
  }

  .section-layout__subtitle {
    font-family: var(--font-headings);
    font-size: 10rem;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    text-orientation: mixed;
    text-align: right;
    line-height: 1.2;
    letter-spacing: -0.02em;
    background-color: blue;
    padding: 16px 8px;
    border: 1px solid #fff;
    border-radius: var(--radius-inner);
    color: white;
    opacity: 0;
    animation: section-fade-up-rotated 560ms ease-out 180ms forwards;
    height: fit-content;
    margin: 0;
    font-variation-settings: "wght" 900, "wdth" 150, "slnt" 0;
    top: 2rem;
  }

  @keyframes detail-fade-up {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes section-fade-up-rotated {
    from {
      opacity: 0;
      transform: rotate(180deg) translateY(18px);
    }
    to {
      opacity: 1;
      transform: rotate(180deg) translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rule-detail__section,
    .rule-detail__footer,
    .section-layout__subtitle {
      animation: none;
      opacity: 1;
    }

    .rule-detail__section,
    .rule-detail__footer {
      transform: none;
    }

    .section-layout__subtitle {
      transform: rotate(180deg);
    }
  }

  @media (max-width: 900px) {
    .rule-detail__description-row {
      grid-template-columns: 1fr;
    }

    .rule-detail__meta {
      border-left: 0;
      border-top: 1px solid var(--color-accent);
      padding-left: 0;
      padding-top: 1rem;
    }
  }
</style>