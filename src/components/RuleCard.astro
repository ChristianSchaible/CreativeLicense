---
interface Props {
  rule: string;
  author?: string;
  visualizedBy?: string;
  href?: string;
  transitionName?: string;
}

const {
  rule,
  author = "Unknown",
  visualizedBy = "Unknown",
  href,
  transitionName,
} = Astro.props;

const ruleUrl = href || '#';
const titleId = `rule-card-${rule.toLowerCase().replace(/[^\w\s-]/g, "").replace(/\s+/g, "-")}`;
---

<a href={ruleUrl} class="rule-card-link" aria-labelledby={titleId}>
  <article class="rule-card" transition:name={transitionName}>
    <header class="rule-card__header">
      <h2 class="rule-card__title" id={titleId}>"{rule}"</h2>
    </header>
    <section class="rule-card__meta" aria-label="Rule credits">
      <div class="rule-card__meta-row">
        <p class="rule-card__meta-label">Author of rule</p>
        <p class="rule-card__meta-value">{author}</p>
      </div>
      <div class="rule-card__meta-row">
        <p class="rule-card__meta-label">Visualized by</p>
        <p class="rule-card__meta-value">{visualizedBy}</p>
      </div>
    </section>
  </article>
</a>

<style>
  .rule-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: opacity 0.2s ease;
  }

  .rule-card {
    display: flex;
    flex-direction: column;
    padding-block: 1rem;
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-inner);
    cursor: pointer;
    margin-bottom: var(--margin);
    margin-left: var(--margin);
    font-variation-settings: "wght" 200, "wdth" 110, "slnt" 0;
    transition: transform 0.3s ease, box-shadow 0.3s ease, font-variation-settings 0.3s ease;
  }

  .rule-card:hover {
    transform: scale(1.01);
    background: none;
    box-shadow: 0 14px 84px 0 rgb(255, 255, 255);
    font-variation-settings: "wght" 700, "wdth" 110, "slnt" 0;
  }

  .rule-card-link:hover,
  .rule-card-link:focus-visible {
    opacity: 0.95;
  }

  .rule-card-link:focus-visible .rule-card {
    outline: 3px solid var(--color-focus-ring);
    outline-offset: 3px;
  }

  .rule-card__header {
    margin: var(--margin);
  }

  .rule-card__title {
    font-family: var(--font-headings);
    font-size: clamp(2rem, 6vw, 5rem);
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .rule-card__meta {
    border-top: 1px solid var(--color-accent);
    margin: 0 var(--margin);
    padding-top: 0.85rem;
    display: flex;
    gap: 1rem;
    flex-direction: column;
  }

  .rule-card__meta-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: baseline;
  }

  .rule-card__meta-label {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.75rem;
    opacity: 0.75;
  }

  .rule-card__meta-value {
    margin: 0;
    font-family: var(--font-headings);
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    line-height: 1.1;
  }

  @media (prefers-reduced-motion: reduce) {
    .rule-card-link,
    .rule-card {
      transition: none;
    }

    .rule-card:hover {
      transform: none;
    }
  }
</style>
