---
import RuleCard from "@components/RuleCard.astro";

interface Rule {
  rule: string;
  description: string;
  process: string;
  author?: string;
  visualizedBy?: string;
  images?: string[];
}

interface Props {
  title: string;
  rules: Rule[];
  section?: string;
  description?: string;
}


const { title, rules, section = 'license', description } = Astro.props;

const gradientPalettes: Record<string, Record<string, string>> = {
  craft: {
    baseA: "rgb(255 150 0)",
    baseB: "rgb(0 0 0)",
    g1A: "rgb(255 196 64)",
    g1B: "rgb(0 0 0)",
    g2A: "rgb(255 132 0)",
    g2B: "rgb(0 0 0)",
    g3A: "rgb(255 98 0)",
    g3B: "rgb(0 0 0)",
    g4A: "rgb(255 170 0)",
    g4B: "rgb(0 0 0)",
    accentA: "rgb(255 120 0)",
    accentB: "rgb(0 0 0)",
  },
  self: {
    baseA: "rgb(0 255 96)",
    baseB: "rgb(0 0 0)",
    g1A: "rgb(118 255 118)",
    g1B: "rgb(0 0 0)",
    g2A: "rgb(0 255 128)",
    g2B: "rgb(0 0 0)",
    g3A: "rgb(64 255 174)",
    g3B: "rgb(0 0 0)",
    g4A: "rgb(0 255 76)",
    g4B: "rgb(0 0 0)",
    accentA: "rgb(0 255 140)",
    accentB: "rgb(0 0 0)",
  },
  work: {
    baseA: "rgb(0 110 255)",
    baseB: "rgb(0 0 0)",
    g1A: "rgb(108 176 255)",
    g1B: "rgb(0 0 0)",
    g2A: "rgb(0 140 255)",
    g2B: "rgb(0 0 0)",
    g3A: "rgb(0 88 255)",
    g3B: "rgb(0 0 0)",
    g4A: "rgb(52 196 255)",
    g4B: "rgb(0 0 0)",
    accentA: "rgb(0 124 255)",
    accentB: "rgb(0 0 0)",
  },
  license: {
    baseA: "rgb(231 227 246)",
    baseB: "rgb(0 3 45)",
    g1A: "rgb(231 227 246)",
    g1B: "rgb(0 3 45)",
    g2A: "rgb(0 0 255)",
    g2B: "rgb(0 68 255)",
    g3A: "rgb(0 2 137)",
    g3B: "rgb(6 87 227)",
    g4A: "rgb(0 76 255)",
    g4B: "rgb(0 200 255)",
    accentA: "rgb(0 51 255)",
    accentB: "rgb(4 134 255)",
  },
};

const palette = gradientPalettes[section] ?? gradientPalettes.license;

const descriptionColumns = (() => {
  if (!description) return [];

  const explicitBreaks = description
    .split(/\n{2,}/)
    .map((part) => part.trim())
    .filter(Boolean);

  if (explicitBreaks.length > 1) return explicitBreaks;

  const sentenceParts =
    description.match(/[^.!?]+[.!?]+(?:\s+|$)|[^.!?]+$/g)?.map((part) => part.trim()).filter(Boolean) ??
    [description];

  if (sentenceParts.length <= 3) return sentenceParts;

  const ratios = [0.4, 0.26, 0.34];
  const targets = ratios.map((ratio) => description.length * ratio);
  const columns = ["", "", ""];
  let currentCol = 0;
  let currentLen = 0;

  sentenceParts.forEach((sentence, idx) => {
    const remainingSentences = sentenceParts.length - idx;
    const remainingColumns = 3 - currentCol;
    const mustAdvance = remainingSentences === remainingColumns;

    if (!mustAdvance && currentCol < 2 && currentLen >= targets[currentCol]) {
      currentCol += 1;
      currentLen = 0;
    }

    columns[currentCol] += (columns[currentCol] ? " " : "") + sentence;
    currentLen += sentence.length;
  });

  return columns.map((part) => part.trim()).filter(Boolean);
})();
---

<section
  class={`section-layout section-layout--${section}`}
  style={`--grad-base-a: ${palette.baseA}; --grad-base-b: ${palette.baseB}; --grad-1-a: ${palette.g1A}; --grad-1-b: ${palette.g1B}; --grad-2-a: ${palette.g2A}; --grad-2-b: ${palette.g2B}; --grad-3-a: ${palette.g3A}; --grad-3-b: ${palette.g3B}; --grad-4-a: ${palette.g4A}; --grad-4-b: ${palette.g4B}; --grad-accent-a: ${palette.accentA}; --grad-accent-b: ${palette.accentB};`}
>
  <div class="section-layout__ambient" aria-hidden="true"></div>
  <header class="section-layout__header">
    {description && (
      <div class="section-layout__description">
        {descriptionColumns.map((column) => (
          <p class="section-layout__description-column">{column}</p>
        ))}
      </div>
    )}
  </header>
<div class="rulesection">
<h1 class="section-layout__subtitle">Input</h1>
<div class="section-layout__rules">
    {rules.map((rule) => {
      const slug = rule.rule
        .toLowerCase()
        .replace(/[^\w\s-]/g, "")
        .replace(/\s+/g, "-");
      const transitionName = `rule-title-${section}-${slug}`;
      return (
        <RuleCard
          rule={rule.rule}
          author={rule.author}
          visualizedBy={rule.visualizedBy}
          href={`/${section}/${slug}`}
          transitionName={transitionName}
        />
      );
    })}
  </div>


</div>
  
</section>

<style>
  .section-layout {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    isolation: isolate;
  }

  .section-layout__ambient {
    position: fixed;
    top: 14vh;
    right: -6vw;
    width: min(72vw, 780px);
    height: min(72vw, 780px);
    border-radius: 50%;
    pointer-events: none;
    z-index: -1;
    opacity: 0.82;
    filter: blur(34px) saturate(1.6);
    background-image:
      radial-gradient(circle at 32% 28%, var(--grad-1-a), transparent 62%),
      radial-gradient(circle at 72% 68%, var(--grad-3-a), transparent 58%),
      linear-gradient(135deg, var(--grad-accent-a), var(--grad-accent-b));
    background-blend-mode: screen, screen, normal;
    animation: section-ambient-float 18s ease-in-out infinite alternate;
    will-change: transform, opacity;
  }

  .section-layout__header {
    transform: translateY(18px);
    animation: section-fade-up 560ms ease-out 80ms forwards;
    background-color: var(--color-background);
    width: 100vw;
    border-radius: var(--radius-inner);
    align-items: center;
    padding: var(--padding);
  }

  .section-layout__title {
    font-family: var(--font-headings);
    font-size: 2rem;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }
  .rulesection {
 display: flex;
  }
  .section-layout__subtitle {
    font-family: var(--font-headings);
    font-size: 10rem;
     writing-mode: vertical-rl;   /* makes text vertical */
  transform: rotate(180deg);   /* flips it to read top-down */
  --subtitle-wdth-max: 75;
  --subtitle-wdth-min: 250;
  --subtitle-wdth: calc(
    var(--subtitle-wdth-max) -
    (var(--subtitle-wdth-max) - var(--subtitle-wdth-min)) * var(--subtitle-shrink-progress, 0)
  );
  font-variation-settings: "wght" var(--subtitle-wdth), "wdth" var(--subtitle-wdth);
  text-orientation: mixed;
  text-align: right;
    line-height: 1.2;
    letter-spacing: -0.02em;
    background-color: rgb(0, 0, 0);
     padding: 16px 8px;
    border: 1px solid #fff;
    border-radius: var(--radius-inner);
    color: white;
    opacity: 0;
    animation: section-fade-up-rotated 560ms ease-out 180ms forwards;
    height: fit-content;
    position: sticky;
    top: 4rem;
    margin-left: var(--margin);

  }

  .section-layout__description {
    display: grid;
    grid-template-columns: .8fr 1.25fr .5fr;
    gap: clamp(1.25rem, 3vw, 2.5rem);
    align-items: start;
    color: rgb(163, 163, 163);
    height: fit-content;
    margin-right: 2rem;
  }

  .section-layout__description-column {
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
  }

  .section-layout__rules {
    display: flex;
    flex-direction: column;
  }

  @keyframes section-fade-up {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes section-fade-up-rotated {
    from {
      opacity: 0;
      transform: rotate(180deg) translateY(18px);
    }
    to {
      opacity: 1;
      transform: rotate(180deg) translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .section-layout__header,
    .section-layout__subtitle {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 1100px) {
    .section-layout__description {
      grid-template-columns: 1fr 1fr;
    }

    .section-layout__description-column:last-child {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 700px) {
    .section-layout__description {
      grid-template-columns: 1fr;
    }

    .section-layout__description-column:last-child {
      grid-column: auto;
    }
  }

  :global(body) {
  min-height: 100vh;
  margin: 0;
  background: var(--color-background);
  }

  @keyframes section-ambient-float {
    from {
      transform: translate3d(calc(var(--ambient-x, 0px) - 10px), calc(var(--ambient-y, 0px) - 6px), 0) scale(0.95);
      opacity: 0.72;
    }
    to {
      transform: translate3d(calc(var(--ambient-x, 0px) + 14px), calc(var(--ambient-y, 0px) + 10px), 0) scale(1.05);
      opacity: 0.9;
    }
  }
</style>

<script data-astro-rerun>
  const setSubtitleShrinkFromScroll = () => {
    const maxDistance = 420;
    const progress = Math.min(window.scrollY / maxDistance, 1);
    document.documentElement.style.setProperty("--subtitle-shrink-progress", progress.toFixed(3));
  };

  const ambientStateKey = "__sectionAmbientState";
  const supportsAmbientMotion =
    window.matchMedia("(pointer: fine)").matches &&
    !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!window[ambientStateKey]) {
    window[ambientStateKey] = {
      initialized: false,
      ambientEl: null,
      frameId: 0,
      currentX: 0,
      currentY: 0,
      targetX: 0,
      targetY: 0,
    };
  }

  const ambientState = window[ambientStateKey];

  const refreshAmbientEl = () => {
    const ambientEl = document.querySelector(".section-layout__ambient");
    if (!(ambientEl instanceof HTMLElement)) return;

    ambientState.ambientEl = ambientEl;
    ambientEl.style.setProperty("--ambient-x", `${ambientState.currentX}px`);
    ambientEl.style.setProperty("--ambient-y", `${ambientState.currentY}px`);
  };

  const updateAmbient = () => {
    ambientState.frameId = 0;
    ambientState.currentX += (ambientState.targetX - ambientState.currentX) * 0.12;
    ambientState.currentY += (ambientState.targetY - ambientState.currentY) * 0.12;

    if (ambientState.ambientEl) {
      ambientState.ambientEl.style.setProperty("--ambient-x", `${ambientState.currentX.toFixed(2)}px`);
      ambientState.ambientEl.style.setProperty("--ambient-y", `${ambientState.currentY.toFixed(2)}px`);
    }

    const settled =
      Math.abs(ambientState.targetX - ambientState.currentX) < 0.15 &&
      Math.abs(ambientState.targetY - ambientState.currentY) < 0.15;

    if (!settled) {
      ambientState.frameId = window.requestAnimationFrame(updateAmbient);
    }
  };

  const queueAmbientUpdate = () => {
    if (!supportsAmbientMotion) return;
    if (!ambientState.frameId) {
      ambientState.frameId = window.requestAnimationFrame(updateAmbient);
    }
  };

  const onPointerMove = (event) => {
    ambientState.targetX = (event.clientX / window.innerWidth - 0.5) * 24;
    ambientState.targetY = (event.clientY / window.innerHeight - 0.5) * 16;
    queueAmbientUpdate();
  };

  const onPointerLeave = () => {
    ambientState.targetX = 0;
    ambientState.targetY = 0;
    queueAmbientUpdate();
  };

  setSubtitleShrinkFromScroll();
  document.addEventListener("astro:page-load", setSubtitleShrinkFromScroll);
  document.addEventListener("astro:after-swap", setSubtitleShrinkFromScroll);
  window.addEventListener("scroll", setSubtitleShrinkFromScroll, { passive: true });

  if (!ambientState.initialized) {
    ambientState.initialized = true;

    if (supportsAmbientMotion) {
      document.addEventListener("pointermove", onPointerMove, { passive: true });
      document.addEventListener("pointerleave", onPointerLeave, { passive: true });
    }
  }

  refreshAmbientEl();
  document.addEventListener("astro:page-load", refreshAmbientEl);
  document.addEventListener("astro:after-swap", refreshAmbientEl);
</script>