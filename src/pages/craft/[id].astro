---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import RuleDetail from "@components/RuleDetail.astro";
import content from "@content/craft.json";

// Generate static paths for all rules
export function getStaticPaths() {
  return content.rules.map((rule) => ({
    params: {
      id: rule.rule
        .toLowerCase()
        .replace(/[^\w\s-]/g, "")
        .replace(/\s+/g, "-"),
    },
    props: {
      rule: rule.rule,
      author: rule.author || "",
      visualizedBy: rule.visualizedBy || "",
      finalOutputImage: typeof rule.finalOutputImage === "string" ? rule.finalOutputImage : "",
      finalOutputImages:
        "finalOutputImages" in rule && Array.isArray(rule.finalOutputImages)
          ? rule.finalOutputImages
          : typeof rule.finalOutputImage === "string" && rule.finalOutputImage
            ? [rule.finalOutputImage]
            : [],
      description: rule.description,
      process: rule.process,
      images: rule.images || [],
    },
  }));
}

interface Props {
  rule: string;
  author: string;
  visualizedBy: string;
  finalOutputImage: string;
  finalOutputImages: string[];
  description: string;
  process: string;
  images: string[];
}

const { rule, author, visualizedBy, finalOutputImage, finalOutputImages, description, process, images } = Astro.props;
const slug = rule
  .toLowerCase()
  .replace(/[^\w\s-]/g, "")
  .replace(/\s+/g, "-");
const transitionName = `rule-title-craft-${slug}`;
---

<Layout title={rule}>
  <Container>
    <RuleDetail
      rule={rule}
      author={author}
      visualizedBy={visualizedBy}
      finalOutputImage={finalOutputImage}
      finalOutputImages={finalOutputImages}
      description={description}
      process={process}
      images={images}
      backHref="/craft"
      backLabel="← Back to Rules of Craft"
      transitionName={transitionName}
    />
  </Container>
</Layout>
