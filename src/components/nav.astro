---
// Navigation component with sticky behavior and mobile hamburger menu
import { withBase } from "../utils/withBase";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

const isActive = (href: string) => {
  const normalizedHref = withBase(href).replace(/\/$/, "") || "/";
  return currentPath === normalizedHref || (normalizedHref !== "/" && currentPath.startsWith(`${normalizedHref}/`));
};
---

<nav class="nav" transition:persist transition:name="site-nav">
  <div class="nav-container">
    <a href={withBase("/")} class="nav-brand" data-magnetic>Creative Licence</a>

    <input
      type="checkbox"
      id="nav-toggle"
      class="nav-toggle"
      aria-controls="site-nav-menu"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    />
    <label for="nav-toggle" class="nav-toggle-label">
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </label>

    <ul class="nav-menu" id="site-nav-menu">
      <li>
        <a href={withBase("/work")} class={isActive("/work") ? "is-active" : undefined} aria-current={isActive("/work") ? "page" : undefined} data-magnetic>Work</a>
      </li>
      <li>
        <a href={withBase("/craft")} class={isActive("/craft") ? "is-active" : undefined} aria-current={isActive("/craft") ? "page" : undefined} data-magnetic>Craft</a>
      </li>
      <li>
        <a href={withBase("/self")} class={isActive("/self") ? "is-active" : undefined} aria-current={isActive("/self") ? "page" : undefined} data-magnetic>Self</a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    background-color: var(--color-background);
    border-bottom: 1px solid var(--color-accent);
    z-index: 1000;
    font-size: 1.1rem;
  }

  .nav-container {
    max-width: var(--size-page-width);
    margin: 0;
    padding: 0 var(--size-page-padding);
    display: flex;
    align-items: center;
    justify-content: flex-start;
    height: 60px;
  }

  .nav-brand {
    font-family: var(--font-headings);
    color: var(--color-accent);
    text-decoration: none;
  }

  .nav-brand:hover {
    color: var(--color-text);
  }

  /* Hamburger toggle (hidden on desktop) */
  .nav-toggle {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }

  .nav-toggle-label {
    display: none;
    flex-direction: column;
    cursor: pointer;
    padding: 10px;
  }

  .nav-toggle-label span {
    width: 25px;
    height: 3px;
    background-color: var(--color-text);
    margin: 3px 0;
    transition: 0.3s;
  }

  /* Navigation menu */
  .nav-menu {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    font-family: var(--font-headings);
  }

  .nav-menu li {
    margin-left: 2rem;
  }

  .nav-menu a {
    color: var(--color-text);
    text-decoration: none;
    font-family: var(--font-headings);
    font-variation-settings: "wdth" 200, "wght" 400, "slnt" 0;
  }

  .nav-menu a:hover,
  .nav-menu a.is-active,
  .nav-menu a[aria-current="page"] {
    color: var(--color-accent);
    font-variation-settings: "wdth" 900, "wght" 700, "slnt" 0;
    transition: color 0.5s ease, font-variation-settings 0.5s ease;
  }

  .nav-menu a:focus-visible,
  .nav-brand:focus-visible,
  .nav-toggle:focus-visible + .nav-toggle-label {
    outline: 3px solid var(--color-focus-ring);
    outline-offset: 4px;
  }

  /* Mobile styles */
  @media (max-width: 768px) {
    .nav-container {
      justify-content: space-between;
    }

    .nav-toggle-label {
      display: flex;
    }

    .nav-menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background-color: var(--color-background);
      border-bottom: 1px solid var(--color-accent);
      flex-direction: column;
      padding: 1rem var(--size-page-padding);
      transform: translateY(-100%);
      opacity: 0;
      visibility: hidden;
      transition: transform 0.3s ease, opacity 0.3s ease, visibility 0.3s ease;
      gap: 0.5rem;
    }

    .nav-menu li {
      margin: 0.5rem 0;
    }

    /* Show menu when toggle is checked */
    .nav-toggle:checked ~ .nav-menu {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
    }

    /* Animate hamburger to X */
    .nav-toggle:checked ~ .nav-toggle-label span:nth-child(1) {
      transform: rotate(45deg) translate(5px, 5px);
    }

    .nav-toggle:checked ~ .nav-toggle-label span:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle:checked ~ .nav-toggle-label span:nth-child(3) {
      transform: rotate(-45deg) translate(7px, -6px);
    }
  }
</style>

<script>
  const normalizePath = (path: string) => path.replace(/\/+$/, "") || "/";

  const navToggle = document.getElementById("nav-toggle") as HTMLInputElement | null;
  const navMenu = document.getElementById("site-nav-menu");

  const syncToggleState = () => {
    if (!navToggle) return;
    navToggle.setAttribute("aria-expanded", navToggle.checked ? "true" : "false");
  };

  const updateActiveNavLink = () => {
    const currentPath = normalizePath(window.location.pathname);
    const navLinks = document.querySelectorAll<HTMLAnchorElement>(".nav-menu a");

    navLinks.forEach((link) => {
      const hrefPath = normalizePath(new URL(link.href, window.location.origin).pathname);
      const isActive = currentPath === hrefPath || (hrefPath !== "/" && currentPath.startsWith(`${hrefPath}/`));

      link.classList.toggle("is-active", isActive);

      if (isActive) {
        link.setAttribute("aria-current", "page");
      } else {
        link.removeAttribute("aria-current");
      }
    });
  };

  navToggle?.addEventListener("change", syncToggleState);
  navMenu?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLAnchorElement)) return;
    if (navToggle && navToggle.checked) {
      navToggle.checked = false;
      syncToggleState();
    }
  });

  updateActiveNavLink();
  document.addEventListener("astro:page-load", updateActiveNavLink);
  document.addEventListener("astro:after-swap", updateActiveNavLink);
  syncToggleState();
</script>