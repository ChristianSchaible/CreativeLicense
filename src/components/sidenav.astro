---
// Nav.astro
const links = [
  { label: "ABOUT", href: "/about" },
  { label: "WORK", href: "/work" },
  { label: "CRAFT", href: "/craft" },
  { label: "SELF", href: "/self" 
  },
];
---

<nav class="side-nav">
  {links.map((link) => (
    <a href={link.href} class="nav-item" data-magnetic>
      {link.label}
    </a>
  ))}
</nav>
<style>
.side-nav {
  --nav-radius: var(--radius-inner);
  flex: 0 0 auto;
  height: clamp(140px, 28vh, 260px);
  min-height: 0;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 0.35rem;
  mix-blend-mode: difference;
  width: 100%;
  min-width: 0;


}

.nav-item {
  writing-mode: vertical-rl;   /* makes text vertical */
  transform: rotate(180deg);   /* flips it to read top-down */
  text-orientation: mixed;
  mix-blend-mode: hard-light;

  padding: 16px 12px;
  border: 1px solid #fff;
    border-radius: var(--nav-radius);

  font-weight: bold;
  letter-spacing: 0.05em;

  text-decoration: none;
  color: white;
  font-family: var(--font-headings);
  font-size: 2.5rem;
  background: var(--color-background);
  

  display: flex;
  align-items: center;
  justify-content: flex-end;

  flex: 1 1 0;
  min-width: 0;
  height: 100%;
  box-sizing: border-box;
  font-variation-settings: "wdth" 100, "wght" 100, "slnt" 0;
  transition: flex-grow 0.35s ease, background 0.35s ease, color 0.35s ease, font-variation-settings 0.35s ease;

}

.side-nav:hover .nav-item {
  flex-grow: 0.8;
}

.side-nav .nav-item:hover {
  flex-grow: 1.4;
}

.nav-item:hover {
  background: rgb(13, 0, 255);
  color: rgb(255, 255, 255);
  font-variation-settings: "wdth" 900, "wght" 700, "slnt" 0;
  padding: 16px 12px;
}

@media (max-width: 820px) {
  .side-nav {
    flex: 0 0 auto;
    height: auto;
    width: 100%;
    min-height: 0;
  }

  .nav-item {
    writing-mode: horizontal-tb;
    transform: none;
    text-orientation: mixed;
    justify-content: center;
    min-height: 3.2rem;
    font-size: clamp(1rem, 3.5vw, 1.35rem);
    padding: 0.5rem 0.75rem;
  }
}

</style>