---
import { withBase } from "../utils/withBase";

interface Props {
  rule: string;
  author: string;
  visualizedBy: string;
  finalOutputImage?: string;
  finalOutputImages?: string[];
  description: string;
  process: string;
  images: string[];
  backHref: string;
  backLabel: string;
  transitionName: string;
}

const {
  rule,
  author,
  visualizedBy,
  finalOutputImage,
  finalOutputImages,
  description,
  process,
  images,
  backHref,
  backLabel,
  transitionName,
} = Astro.props;

const outputImages = finalOutputImages?.length ? finalOutputImages : finalOutputImage ? [finalOutputImage] : [];
---

<article class="rule-detail">
  <header class="rule-detail__header" transition:name={transitionName}>
    <h1 class="rule-detail__title">"{rule}"</h1>
  </header>

  <div class="output">
    <h2 class="section-layout__subtitle">Output</h2>

    <div class="rule-detail__content">
      {outputImages.length > 0 && (
        <div class="rule-detail__final-output">
          <h2 class="rule-detail__subtitle">Final Output</h2>
          <div class="rule-detail__gallery">
            {outputImages.map((image, index) => (
              <figure class="rule-detail__figure">
                <img
                  src={withBase(image)}
                  alt={outputImages.length > 1 ? `Final output ${index + 1} for ${rule}` : `Final output for ${rule}`}
                  class="rule-detail__img"
                />
              </figure>
            ))}
          </div>
        </div>
      )}

      <section class="rule-detail__section">
        <div class="rule-detail__description-row">
          <p class="rule-detail__text">{description}</p>

          <aside class="rule-detail__meta" aria-label="Rule attribution">
            {author && (
              <p class="rule-detail__meta-item">
                <span class="rule-detail__meta-label">Author</span>
                <span class="rule-detail__meta-value">{author}</span>
              </p>
            )}
            {visualizedBy && (
              <p class="rule-detail__meta-item">
                <span class="rule-detail__meta-label">Visualized By</span>
                <span class="rule-detail__meta-value">{visualizedBy}</span>
              </p>
            )}
          </aside>
        </div>
      </section>

      <section class="rule-detail__section">
        <h2 class="rule-detail__subtitle">Process</h2>
        <p class="rule-detail__text">{process}</p>
      </section>

      {images.length > 0 && (
        <section class="rule-detail__section rule-detail__images">
          <div class="rule-detail__gallery">
            {images.map((image) => (
              <figure class="rule-detail__figure">
                <img src={withBase(image)} alt={rule} class="rule-detail__img" />
              </figure>
            ))}
          </div>
        </section>
      )}
    </div>
  </div>

  <footer class="rule-detail__footer">
    <a href={backHref} class="rule-detail__back-link">{backLabel}</a>
  </footer>
</article>

<style>
  .rule-detail {
    width: 100%;
  }

  .rule-detail__header {
    margin: var(--margin);
  }

  .rule-detail__title {
    font-family: var(--font-headings);
    font-size: clamp(2.5rem, 8vw, 7rem);
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .rule-detail__content {
    max-width: 65ch;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .rule-detail__section {
    opacity: 0;
    transform: translateY(18px);
    animation: detail-fade-up 560ms ease-out forwards;
    display: flex;
    flex-direction: column;
  }

  .rule-detail__section:nth-of-type(1) {
    animation-delay: 80ms;
    border: 1px solid var(--color-accent);
    padding: var(--padding);
    border-radius: var(--radius-inner);
  }

  .rule-detail__section:nth-of-type(2) {
    animation-delay: 180ms;
    border: 1px solid var(--color-accent);
    padding: var(--padding);
    border-radius: var(--radius-inner);
  }

  .rule-detail__section:nth-of-type(3) {
    animation-delay: 280ms;
    border: 1px solid var(--color-accent);
    padding: var(--padding);
    border-radius: var(--radius-inner);
  }

  .rule-detail__subtitle {
    font-family: var(--font-headings);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-accent);
    padding-bottom: 0.75rem;
  }

  .rule-detail__text {
    font-size: clamp(1rem, 2vw, 1.125rem);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .rule-detail__description-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(14rem, 20rem);
    gap: 1.25rem;
    align-items: start;
  }

  .rule-detail__meta {
    border-left: 1px solid var(--color-accent);
    padding-left: 1rem;
  }

  .rule-detail__meta-item {
    margin: 0 0 1rem;
    display: grid;
    gap: 0.2rem;
  }

  .rule-detail__meta-label {
    font-family: var(--font-headings);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.8;
  }

  .rule-detail__meta-value {
    font-size: 1rem;
    line-height: 1.4;
  }

  .rule-detail__images {
    max-width: 100%;
  }

  .rule-detail__final-output {
    opacity: 0;
    transform: translateY(18px);
    animation: detail-fade-up 560ms ease-out 80ms forwards;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border: 1px solid var(--color-accent);
    padding: var(--padding);
    border-radius: var(--radius-inner);
  }

  .rule-detail__gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .rule-detail__final-output .rule-detail__gallery {
    display: flex;
    flex-wrap: nowrap;
    gap: 1rem;
    overflow-x: auto;
    overflow-y: hidden;
    padding-bottom: 0.25rem;
    scrollbar-width: thin;
  }

  .rule-detail__figure {
    margin: 0;
  }

  .rule-detail__final-output .rule-detail__figure {
    flex: 0 0 auto;
  }

  .rule-detail__img {
    width: 100%;
    height: auto;
    display: block;
  }

  .rule-detail__final-output .rule-detail__img {
    width: auto;
    height: clamp(180px, 28vw, 260px);
    max-width: none;
    object-fit: cover;
  }

  .rule-detail__footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-accent);
    opacity: 0;
    transform: translateY(18px);
    animation: detail-fade-up 560ms ease-out 360ms forwards;
  }

  .rule-detail__back-link {
    font-family: var(--font-headings);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: var(--color-accent);
    transition: opacity 0.3s ease;
  }

  .rule-detail__back-link:hover,
  .rule-detail__back-link:focus-visible {
    opacity: 0.7;
  }

  .output {
    display: flex;
    flex-direction: row;
    gap: 1rem;
  }

  .section-layout__subtitle {
    font-family: var(--font-headings);
    font-size: 10rem;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    text-orientation: mixed;
    text-align: right;
    line-height: 1.2;
    letter-spacing: -0.02em;
    background-color: blue;
    padding: 16px 8px;
    border: 1px solid #fff;
    border-radius: var(--radius-inner);
    color: white;
    opacity: 0;
    animation: section-fade-up-rotated 560ms ease-out 180ms forwards;
    height: fit-content;
    margin: 0;
    font-variation-settings: "wght" 900, "wdth" 150, "slnt" 0;
    top: 2rem;
  }

  @keyframes detail-fade-up {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes section-fade-up-rotated {
    from {
      opacity: 0;
      transform: rotate(180deg) translateY(18px);
    }
    to {
      opacity: 1;
      transform: rotate(180deg) translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rule-detail__section,
    .rule-detail__footer,
    .section-layout__subtitle {
      animation: none;
      opacity: 1;
    }

    .rule-detail__section,
    .rule-detail__footer {
      transform: none;
    }

    .section-layout__subtitle {
      transform: rotate(180deg);
    }
  }

  @media (max-width: 900px) {
    .rule-detail__description-row {
      grid-template-columns: 1fr;
    }

    .rule-detail__meta {
      border-left: 0;
      border-top: 1px solid var(--color-accent);
      padding-left: 0;
      padding-top: 1rem;
    }
  }
</style>